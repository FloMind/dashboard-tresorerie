# ══════════════════════════════════════════════════════════════
# secrets.toml.example -- FloMind Dashboard Tresorerie
# Copier en secrets.toml et adapter. Ne JAMAIS committer secrets.toml.
# ══════════════════════════════════════════════════════════════

# ── Authentification RBAC ────────────────────────────────────
[auth]
# Mot de passe DG (hash bcrypt -- generer avec : python -c "import bcrypt; print(bcrypt.hashpw(b'motdepasse', bcrypt.gensalt()).decode())")
dg_password_hash = "$2b$12$exemple_hash_bcrypt_ici"
demo_password    = "flomind2026"

# ── Source de donnees ─────────────────────────────────────────
[treso]
mode = "excel"   # "excel" | "sql"

# Si mode = "sql" (Sage 100 Premium via SQL Server) :
# server   = "192.168.1.10"
# database = "GESCOM_2024"
# username = "lecteur_readonly"
# password = "mot_de_passe_sql"

# Chemins fichiers Excel (relatifs au dossier du projet) :
flux_path   = "data/treso_flux.xlsx"
soldes_path = "data/treso_soldes.xlsx"
bfr_path    = "data/treso_bfr.xlsx"

# ── Google Sheets bridge (V1.5 -- optionnel) ─────────────────
# [gcp_service_account]
# type                        = "service_account"
# project_id                  = "flomind-project"
# private_key_id              = "..."
# private_key                 = "-----BEGIN RSA PRIVATE KEY-----\n..."
# client_email                = "flomind@project.iam.gserviceaccount.com"
# client_id                   = "..."
# auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
# token_uri                   = "https://oauth2.googleapis.com/token"
